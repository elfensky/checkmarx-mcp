# Checkmarx One MCP Server Configuration
# Copy to .env and fill in your values.

# Required:
CHECKMARX_TENANT="your-tenant-name"
CHECKMARX_BASE_URI="https://ast.checkmarx.net"   # or regional: eu.ast, us.ast, etc.

# API Key authentication (refresh_token flow):
CHECKMARX_API_KEY="your-api-key-here"

# OAuth2 client credentials (takes priority over API key if both are set):
# CHECKMARX_CLIENT_ID="your-client-id"
# CHECKMARX_CLIENT_SECRET="your-client-secret"

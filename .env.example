# Checkmarx One credentials
# Copy this file to .env and fill in your values.
#
# Required for all scripts:
TENANT="your-tenant-name"
BASE_URI="https://ast.checkmarx.net"   # or regional: eu.ast, us.ast, etc.

# API Key authentication (used by checkmarx.api.sh and utils/):
APIKEY="your-api-key-here"

# OAuth2 client credentials (used by checkmarx.oauth.sh):
# If both CLIENT_ID and CLIENT_SECRET are set, they take priority over APIKEY.
# CLIENT_ID="your-client-id"
# CLIENT_SECRET="your-client-secret"
